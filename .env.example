NEXT_PUBLIC_SITE_URL=https://petit.example.com

# Mailchimp Marketing API
# Get these from https://admin.mailchimp.com/account/api/
MAILCHIMP_API_KEY=
# The server prefix is the suffix on your API key, e.g. us1, us21
MAILCHIMP_SERVER_PREFIX=
# Audience (list) ID from Audience > Settings > Audience name and defaults
MAILCHIMP_AUDIENCE_ID=
